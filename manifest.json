{
  "manifest_version": 3,
  "name": "BarcodeGen",
  "version": "1.2.0",
  "description": "Generate QR codes and barcodes in the side panel. 100% offline — no data collected.",
  "permissions": ["sidePanel", "bluetooth"],
  "action": {
    "default_title": "Open BarcodeGen",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
